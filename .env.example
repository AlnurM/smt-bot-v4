# Binance environment: testnet or production
BINANCE_ENV=testnet

# Binance API credentials — get from testnet.binancefuture.com (testnet) or binance.com (production)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram chat ID — only messages from this ID will be processed
ALLOWED_CHAT_ID=123456789

# PostgreSQL connection string — contains password, never log this value
DATABASE_URL=postgresql+asyncpg://ctb:ctb_password@db:5432/ctb

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Risk management defaults — seeded to DB on first boot; DB value wins after first Telegram /risk command
BASE_STAKE_PCT=3.0
CURRENT_STAKE_PCT=3.0
MAX_STAKE_PCT=8.0
MIN_RR_RATIO=3.0
MAX_OPEN_POSITIONS=5
DAILY_LOSS_LIMIT_PCT=5.0
LEVERAGE=5

# Strategy criteria defaults — seeded to DB on first boot
BACKTEST_PERIOD_MONTHS=6
MIN_TOTAL_RETURN_PCT=200.0
MAX_DRAWDOWN_PCT=-12.0
MIN_WIN_RATE_PCT=55.0
MIN_PROFIT_FACTOR=1.8
MIN_TRADES=30
MIN_AVG_RR=2.0

# Anthropic API key — required for Claude strategy generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model — do not change unless you know what you are doing
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Market scanner — comma-separated list of approved coins (overrides hardcoded default)
# COIN_WHITELIST=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
TOP_N_COINS=10
MIN_VOLUME_USDT=50000000.0
CONSECUTIVE_EMPTY_CYCLES_ALERT=3
